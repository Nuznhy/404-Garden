---
import "../styles/global.css";
import {
  getLocaleFromUrl,
  locales,
  localizePath,
  useTranslations,
  type Locale,
} from "../i18n";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const currentLocale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(currentLocale);
const {
  title,
  description = t.subtitle,
} = Astro.props;

const currentPathWithoutLocale = Astro.url.pathname.replace(
  new RegExp(`^/(${locales.join("|")})(?=/|$)`),
  "",
) || "/";
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} | 404 Garden</title>
  </head>

  <body>
    <div class="page-shell">
      <header class="site-header">
        <p class="eyebrow">{t.eyebrow}</p>
        <h1><a href={localizePath("/", currentLocale)}>{t.title}</a></h1>
        <p class="tagline">
          {t.subtitle}
        </p>
        <nav class="language-switcher" aria-label={t.language}>
          {locales.map((locale) => (
            <a
              href={localizePath(currentPathWithoutLocale, locale)}
              aria-current={locale === currentLocale ? "true" : undefined}
            >
              {t.languages[locale]}
            </a>
          ))}
        </nav>
      </header>

      <hr />

      <main>
        <slot />
      </main>

      <hr />

      <footer class="site-footer">
        <p>{t.footer}</p>
      </footer>
    </div>
  </body>
</html>
